# ============================================================
# .env.example — Costa Brava Rent a Boat
# Copy this file to .env and fill in real values.
# Never commit your actual .env file to version control.
# ============================================================


# === REQUIRED ===

# PostgreSQL connection string (Neon, Supabase, or any Postgres provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret key used to sign JWT tokens for customer auth. Min 32 chars, random.
JWT_SECRET=replace-with-a-random-string-of-at-least-32-characters

# PIN used to access the admin CRM panel (numeric recommended)
ADMIN_PIN=123456


# === SERVER ===

# Port the Express server listens on. Defaults to 5000 if not set.
# OPTIONAL
PORT=5000

# Node environment: "development" or "production"
# OPTIONAL — defaults to "development" when not set
NODE_ENV=development

# Public base URL of the application (no trailing slash).
# Used for building absolute URLs in emails, webhooks, sitemaps, etc.
# Defaults to https://costabravarentaboat.app in production.
# OPTIONAL
APP_URL=https://costabravarentaboat.app

# Alias for APP_URL used by some internal modules (sitemaps, SEO injector).
# Should match APP_URL.
# OPTIONAL
BASE_URL=https://costabravarentaboat.app


# === PAYMENTS (Stripe) ===

# Stripe secret key (sk_live_... for production, sk_test_... for development)
# OPTIONAL — payment features are disabled when not set
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret for verifying incoming webhook events
# Found in the Stripe Dashboard under Webhooks > your endpoint > Signing secret
# OPTIONAL — webhook signature verification is skipped when not set
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here


# === EMAIL (SendGrid) ===

# SendGrid API key for sending transactional emails
# OPTIONAL — email sending is disabled when not set
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Verified sender email address configured in your SendGrid account
# OPTIONAL — falls back to costabravarentaboat@gmail.com
SENDGRID_FROM_EMAIL=no-reply@costabravarentaboat.app

# Email address that receives booking notifications sent to the boat owner
# OPTIONAL — falls back to costabravarentaboat@gmail.com
OWNER_EMAIL=costabravarentaboat@gmail.com


# === WHATSAPP (Twilio) ===

# Twilio Account SID (starts with "AC")
# OPTIONAL — WhatsApp messaging is disabled when not set
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token (found in the Twilio Console)
# OPTIONAL
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Twilio WhatsApp sender number in E.164 format prefixed with "whatsapp:"
# Use the Twilio Sandbox number for development or your approved production number.
# OPTIONAL — defaults to whatsapp:+14155238886 (Twilio sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp number of the boat owner for internal notifications (E.164, no prefix)
# OPTIONAL
OWNER_WHATSAPP_NUMBER=+34611500372

# Public URL Twilio uses to POST incoming WhatsApp messages (your webhook endpoint).
# Usually the same as BASE_URL. Twilio must be able to reach this URL.
# OPTIONAL — derived from the incoming request host when not set
# BASE_URL already covers this; kept separate for clarity if needed


# === AI / OPENAI ===

# OpenAI API key used for the WhatsApp chatbot (gpt-4o-mini) and RAG embeddings
# OPTIONAL — AI chatbot features are disabled when not set
OPENAI_API_KEY=sk-your_openai_api_key_here

# Alternative OpenAI-compatible API key used by Replit AI integrations (image, audio, chat)
# OPTIONAL — only required when using Replit's built-in AI integration modules
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your_replit_ai_integrations_key_here

# Base URL for the Replit AI integrations OpenAI-compatible endpoint
# OPTIONAL — defaults to OpenAI's standard endpoint
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1


# === AUTH (Replit OIDC) ===

# Replit application ID, used for OIDC-based customer authentication via Replit Auth.
# Automatically set by Replit in hosted environments.
# OPTIONAL — Replit Auth is only active on Replit deployments
REPL_ID=your-replit-app-id

# Comma-separated list of allowed Replit deployment domains.
# Automatically set by Replit in hosted environments.
# OPTIONAL
REPLIT_DOMAINS=your-app.replit.app

# OIDC issuer URL for Replit Auth.
# OPTIONAL — defaults to https://replit.com/oidc
ISSUER_URL=https://replit.com/oidc

# Secret used to sign Replit Auth session cookies. Should be long and random.
# OPTIONAL — only required when Replit Auth (OIDC) is enabled
SESSION_SECRET=replace-with-a-random-session-secret-min-32-chars

# Base URL prepended to the password reset token link sent in reset emails.
# Example: https://costabravarentaboat.app/reset-password
# OPTIONAL — falls back to APP_URL/reset-password when not set
AUTH_RESET_URL_BASE=https://costabravarentaboat.app/reset-password


# === STORAGE (Replit Object Storage) ===

# Colon-separated list of public bucket paths searched when serving public assets.
# OPTIONAL — only relevant when using Replit Object Storage
PUBLIC_OBJECT_SEARCH_PATHS=public/images:public/assets

# Directory prefix used for private object storage reads/writes.
# OPTIONAL — only relevant when using Replit Object Storage
PRIVATE_OBJECT_DIR=private


# === AVAILABILITY / ICAL ===

# Secret token that protects the iCal feed endpoint from public access.
# Any request to /api/availability/ical must include this token.
# OPTIONAL — the iCal feed is unprotected when not set
ICAL_FEED_TOKEN=replace-with-a-random-ical-token


# === MONITORING (Sentry) ===

# Sentry DSN for error tracking and performance monitoring.
# OPTIONAL — Sentry is disabled when not set
SENTRY_DSN=https://your_sentry_public_key@o0.ingest.sentry.io/0

# Sentry auth token for MCP server integration (separate from DSN).
# Generate at https://sentry.io/settings/account/api/auth-tokens/
# OPTIONAL — Sentry MCP server is disabled when not set
SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token_here

# Neon API key for MCP database management server.
# Generate at https://console.neon.tech/app/settings/api-keys
# OPTIONAL — Neon MCP server is disabled when not set
NEON_API_KEY=your_neon_api_key_here


# === BLOG AUTOPILOT (Claude AI) ===

# Anthropic API key for blog autopilot content generation (Claude Sonnet 4.6)
# Generate at https://console.anthropic.com/settings/keys
# OPTIONAL — blog autopilot is disabled when not set
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Unsplash Access Key for automatic blog post featured images
# Register at https://unsplash.com/developers
# OPTIONAL — posts will have no featured image when not set
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
